---
# Пример файла секретов - переименуйте в секреты.yml и заполните реальными значениями

# Пароли
grafana_admin_user: admin
grafana_admin_password: "сильный_пароль"

# Токены и ключи
gitlab_runner_token: "ваш_runner_токен"
docker_registry_password: "пароль_реестра"

# SSH ключи
ssh_публичные_ключи:
  - "ssh-rsa AAAAB3NzaC1yc2E... user@example.com"

# API ключи
yc_token: "ваш_yandex_cloud_токен"
