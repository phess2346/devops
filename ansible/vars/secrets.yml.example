---
# Example secrets file - rename to secrets.yml and fill with real values

# Passwords
grafana_admin_user: admin
grafana_admin_password: "strong_password_here"

# Tokens and keys
gitlab_runner_token: "your_runner_token"
docker_registry_password: "registry_password"

# SSH keys
ssh_public_keys:
  - "ssh-rsa AAAAB3NzaC1yc2E... user@example.com"

# API keys
yc_token: "your_yandex_cloud_token_here"

# Database passwords
postgres_password: "postgres_password_here"
redis_password: "redis_password_here"
